@echo off
setlocal
chcp 65001 >nul
cd /d "%~dp0\..\.."

set "PORT=%~1"
if "%PORT%"=="" set "PORT=8741"

set "API_KEY=%~2"
if "%API_KEY%"=="" set "API_KEY=worker-%PORT%-change-me"

set "NAME=%~3"
if "%NAME%"=="" set "NAME=openclaude-agent-%PORT%"

set "ENV_FILE=%~4"
if "%ENV_FILE%"=="" set "ENV_FILE=.env"
set "DRY_RUN=%~5"

if "%OPENCLAUDE_AGENT_RUNNER_CWD%"=="" set "OPENCLAUDE_AGENT_RUNNER_CWD=/workspace"
if "%OPENCLAUDE_AGENT_RUNNER_MAX_TURNS%"=="" set "OPENCLAUDE_AGENT_RUNNER_MAX_TURNS=8"
if "%OPENCLAUDE_AGENT_RUNNER_TIMEOUT_MS%"=="" set "OPENCLAUDE_AGENT_RUNNER_TIMEOUT_MS=120000"
if "%OPENCLAUDE_AGENT_RUNNER_PERMISSION_MODE%"=="" set "OPENCLAUDE_AGENT_RUNNER_PERMISSION_MODE=bypassPermissions"
if "%OPENCLAUDE_AGENT_RUNNER_DISALLOWED_TOOLS%"=="" set "OPENCLAUDE_AGENT_RUNNER_DISALLOWED_TOOLS="
if "%MCPR_HOST%"=="" set "MCPR_HOST=host.docker.internal"
if "%MCPR_PORT%"=="" set "MCPR_PORT=3282"
if "%OPENRAG_URL%"=="" set "OPENRAG_URL=http://host.docker.internal:3000"
if "%OPENRAG_MCP_TIMEOUT%"=="" set "OPENRAG_MCP_TIMEOUT=60"
if "%CAMOFOX_URL%"=="" set "CAMOFOX_URL=http://host.docker.internal:9377"
if "%CAMOFOX_MCP_TIMEOUT%"=="" set "CAMOFOX_MCP_TIMEOUT=60"
if "%HINDSIGHT_URL%"=="" set "HINDSIGHT_URL=http://host.docker.internal:8888"
if "%HINDSIGHT_BANK_ID%"=="" set "HINDSIGHT_BANK_ID=openclaude-agent"
if "%HINDSIGHT_MCP_TIMEOUT%"=="" set "HINDSIGHT_MCP_TIMEOUT=60"
if "%OPENCLAUDE_REPLICA_TELEGRAM_ENABLED%"=="" set "OPENCLAUDE_REPLICA_TELEGRAM_ENABLED=0"
if "%OPENCLAUDE_REPLICA_CRON_ENABLED%"=="" set "OPENCLAUDE_REPLICA_CRON_ENABLED=0"
if "%OPENCLAUDE_REPLICA_CRON_TICK_SECONDS%"=="" set "OPENCLAUDE_REPLICA_CRON_TICK_SECONDS=60"
if "%OPENCLAUDE_REPLICA_OUROBOROS_ENABLED%"=="" set "OPENCLAUDE_REPLICA_OUROBOROS_ENABLED=0"
if "%OPENCLAUDE_REPLICA_CONSCIOUSNESS_ENABLED%"=="" set "OPENCLAUDE_REPLICA_CONSCIOUSNESS_ENABLED=0"
if "%OPENCLAUDE_REPLICA_INFINITE_TASKS_ENABLED%"=="" set "OPENCLAUDE_REPLICA_INFINITE_TASKS_ENABLED=0"
if "%OPENCLAUDE_REPLICA_OUROBOROS_WAKEUP_MIN_SECONDS%"=="" set "OPENCLAUDE_REPLICA_OUROBOROS_WAKEUP_MIN_SECONDS=300"
if "%OPENCLAUDE_REPLICA_OUROBOROS_WAKEUP_MAX_SECONDS%"=="" set "OPENCLAUDE_REPLICA_OUROBOROS_WAKEUP_MAX_SECONDS=7200"
if "%OPENCLAUDE_REPLICA_OUROBOROS_MAX_ROUNDS%"=="" set "OPENCLAUDE_REPLICA_OUROBOROS_MAX_ROUNDS=3"
if "%OPENCLAUDE_REPLICA_OUROBOROS_BUDGET_FRACTION%"=="" set "OPENCLAUDE_REPLICA_OUROBOROS_BUDGET_FRACTION=0.1"
if "%OPENCLAUDE_REPLICA_TELEGRAM_BOT_TOKEN%"=="" set "OPENCLAUDE_REPLICA_TELEGRAM_BOT_TOKEN=%TELEGRAM_BOT_TOKEN%"
if "%OPENCLAUDE_REPLICA_TELEGRAM_HOME_CHAT_ID%"=="" set "OPENCLAUDE_REPLICA_TELEGRAM_HOME_CHAT_ID=%OPENCLAUDE_TELEGRAM_HOME_CHAT_ID%"
if "%OPENCLAUDE_REPLICA_TELEGRAM_ALLOWED_CHAT_IDS%"=="" set "OPENCLAUDE_REPLICA_TELEGRAM_ALLOWED_CHAT_IDS=%OPENCLAUDE_TELEGRAM_ALLOWED_CHAT_IDS%"
if "%OPENCLAUDE_REPLICA_TELEGRAM_ALLOWED_USER_IDS%"=="" set "OPENCLAUDE_REPLICA_TELEGRAM_ALLOWED_USER_IDS=%OPENCLAUDE_TELEGRAM_ALLOWED_USER_IDS%"
if "%WEB_SEARCH_PROVIDER%"=="" set "WEB_SEARCH_PROVIDER=auto"
set "PROVIDER_SUMMARY=%OPENCLAUDE_PROVIDER%"
if "%PROVIDER_SUMMARY%"=="" if not "%CLAUDE_CODE_USE_OPENAI%"=="" set "PROVIDER_SUMMARY=openai"
if "%PROVIDER_SUMMARY%"=="" if not "%CLAUDE_CODE_USE_GEMINI%"=="" set "PROVIDER_SUMMARY=gemini"
if "%PROVIDER_SUMMARY%"=="" if not "%CLAUDE_CODE_USE_MISTRAL%"=="" set "PROVIDER_SUMMARY=mistral"
if "%PROVIDER_SUMMARY%"=="" if not "%CLAUDE_CODE_USE_GITHUB%"=="" set "PROVIDER_SUMMARY=github"
if "%PROVIDER_SUMMARY%"=="" set "PROVIDER_SUMMARY=default"
set "PROVIDER_MODEL_SUMMARY=%OPENCLAUDE_MODEL%"
if "%PROVIDER_MODEL_SUMMARY%"=="" set "PROVIDER_MODEL_SUMMARY=%OPENAI_MODEL%"
if "%PROVIDER_MODEL_SUMMARY%"=="" set "PROVIDER_MODEL_SUMMARY=%GEMINI_MODEL%"
if "%PROVIDER_MODEL_SUMMARY%"=="" set "PROVIDER_MODEL_SUMMARY=%MISTRAL_MODEL%"
if "%PROVIDER_MODEL_SUMMARY%"=="" set "PROVIDER_MODEL_SUMMARY=%ANTHROPIC_MODEL%"
if "%PROVIDER_MODEL_SUMMARY%"=="" set "PROVIDER_MODEL_SUMMARY=default"

set "ENV_FILE_ARGS="
if exist "%ENV_FILE%" set "ENV_FILE_ARGS=--env-file %ENV_FILE%"
set "PROVIDER_ENV_ARGS="
if not "%CLAUDE_CODE_USE_OPENAI%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e CLAUDE_CODE_USE_OPENAI=%CLAUDE_CODE_USE_OPENAI%"
if not "%CLAUDE_CODE_USE_GEMINI%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e CLAUDE_CODE_USE_GEMINI=%CLAUDE_CODE_USE_GEMINI%"
if not "%CLAUDE_CODE_USE_MISTRAL%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e CLAUDE_CODE_USE_MISTRAL=%CLAUDE_CODE_USE_MISTRAL%"
if not "%CLAUDE_CODE_USE_GITHUB%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e CLAUDE_CODE_USE_GITHUB=%CLAUDE_CODE_USE_GITHUB%"
if not "%CLAUDE_CODE_USE_BEDROCK%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e CLAUDE_CODE_USE_BEDROCK=%CLAUDE_CODE_USE_BEDROCK%"
if not "%CLAUDE_CODE_USE_VERTEX%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e CLAUDE_CODE_USE_VERTEX=%CLAUDE_CODE_USE_VERTEX%"
if not "%CLAUDE_CODE_USE_FOUNDRY%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e CLAUDE_CODE_USE_FOUNDRY=%CLAUDE_CODE_USE_FOUNDRY%"
if not "%OPENCLAUDE_PROVIDER%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e OPENCLAUDE_PROVIDER=%OPENCLAUDE_PROVIDER%"
if not "%OPENCLAUDE_BASE_URL%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e OPENCLAUDE_BASE_URL=%OPENCLAUDE_BASE_URL%"
if not "%OPENCLAUDE_MODEL%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e OPENCLAUDE_MODEL=%OPENCLAUDE_MODEL%"
if not "%OPENCLAUDE_API_KEY%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e OPENCLAUDE_API_KEY=%OPENCLAUDE_API_KEY%"
if not "%OPENAI_BASE_URL%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e OPENAI_BASE_URL=%OPENAI_BASE_URL%"
if not "%OPENAI_MODEL%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e OPENAI_MODEL=%OPENAI_MODEL%"
if not "%OPENAI_API_KEY%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e OPENAI_API_KEY=%OPENAI_API_KEY%"
if not "%CODEX_API_KEY%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e CODEX_API_KEY=%CODEX_API_KEY%"
if not "%CODEX_CREDENTIAL_SOURCE%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e CODEX_CREDENTIAL_SOURCE=%CODEX_CREDENTIAL_SOURCE%"
if not "%CHATGPT_ACCOUNT_ID%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e CHATGPT_ACCOUNT_ID=%CHATGPT_ACCOUNT_ID%"
if not "%CODEX_ACCOUNT_ID%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e CODEX_ACCOUNT_ID=%CODEX_ACCOUNT_ID%"
if not "%ANTHROPIC_BASE_URL%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e ANTHROPIC_BASE_URL=%ANTHROPIC_BASE_URL%"
if not "%ANTHROPIC_MODEL%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e ANTHROPIC_MODEL=%ANTHROPIC_MODEL%"
if not "%ANTHROPIC_API_KEY%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e ANTHROPIC_API_KEY=%ANTHROPIC_API_KEY%"
if not "%GEMINI_BASE_URL%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e GEMINI_BASE_URL=%GEMINI_BASE_URL%"
if not "%GEMINI_MODEL%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e GEMINI_MODEL=%GEMINI_MODEL%"
if not "%GEMINI_API_KEY%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e GEMINI_API_KEY=%GEMINI_API_KEY%"
if not "%GOOGLE_API_KEY%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e GOOGLE_API_KEY=%GOOGLE_API_KEY%"
if not "%MISTRAL_BASE_URL%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e MISTRAL_BASE_URL=%MISTRAL_BASE_URL%"
if not "%MISTRAL_MODEL%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e MISTRAL_MODEL=%MISTRAL_MODEL%"
if not "%MISTRAL_API_KEY%"=="" set "PROVIDER_ENV_ARGS=%PROVIDER_ENV_ARGS% -e MISTRAL_API_KEY=%MISTRAL_API_KEY%"

if /I "%DRY_RUN%"=="--dry-run" (
  echo Replica dry run
  echo Port: %PORT%
  echo API key: %API_KEY%
  echo Container: %NAME%
  echo Env file: %ENV_FILE%
  echo Telegram enabled: %OPENCLAUDE_REPLICA_TELEGRAM_ENABLED%
  echo Cron enabled: %OPENCLAUDE_REPLICA_CRON_ENABLED%
  echo Cron tick seconds: %OPENCLAUDE_REPLICA_CRON_TICK_SECONDS%
  echo Ouroboros enabled: %OPENCLAUDE_REPLICA_OUROBOROS_ENABLED%
  echo Consciousness enabled: %OPENCLAUDE_REPLICA_CONSCIOUSNESS_ENABLED%
  echo Infinite tasks enabled: %OPENCLAUDE_REPLICA_INFINITE_TASKS_ENABLED%
  echo Ouroboros wakeup: %OPENCLAUDE_REPLICA_OUROBOROS_WAKEUP_MIN_SECONDS%-%OPENCLAUDE_REPLICA_OUROBOROS_WAKEUP_MAX_SECONDS%s
  echo Ouroboros max rounds: %OPENCLAUDE_REPLICA_OUROBOROS_MAX_ROUNDS%
  echo Ouroboros budget fraction: %OPENCLAUDE_REPLICA_OUROBOROS_BUDGET_FRACTION%
  echo Runner cwd: %OPENCLAUDE_AGENT_RUNNER_CWD%
  echo Runner blocked tools: %OPENCLAUDE_AGENT_RUNNER_DISALLOWED_TOOLS%
  echo Provider: %PROVIDER_SUMMARY%
  echo Provider model: %PROVIDER_MODEL_SUMMARY%
  echo WebSearch provider: %WEB_SEARCH_PROVIDER%
  echo MCP Router: %MCPR_HOST%:%MCPR_PORT%
  echo OpenRAG: %OPENRAG_URL%
  echo Camofox: %CAMOFOX_URL%
  echo Hindsight: %HINDSIGHT_URL% bank=%HINDSIGHT_BANK_ID%
  exit /b 0
)

docker build -t openclaude-agent:local .
docker rm -f "%NAME%" >nul 2>nul

docker run -d ^
  --name "%NAME%" ^
  %ENV_FILE_ARGS% ^
  %PROVIDER_ENV_ARGS% ^
  --add-host host.docker.internal:host-gateway ^
  -p "%PORT%:%PORT%" ^
  -e OPENCLAUDE_AGENT_API_ENABLED=1 ^
  -e OPENCLAUDE_AGENT_API_HOST=0.0.0.0 ^
  -e OPENCLAUDE_AGENT_API_PORT="%PORT%" ^
  -e OPENCLAUDE_AGENT_API_KEY="%API_KEY%" ^
  -e OPENCLAUDE_AGENT_CRON_ENABLED="%OPENCLAUDE_REPLICA_CRON_ENABLED%" ^
  -e OPENCLAUDE_AGENT_CRON_TICK_SECONDS="%OPENCLAUDE_REPLICA_CRON_TICK_SECONDS%" ^
  -e OPENCLAUDE_TELEGRAM_ENABLED="%OPENCLAUDE_REPLICA_TELEGRAM_ENABLED%" ^
  -e TELEGRAM_BOT_TOKEN="%OPENCLAUDE_REPLICA_TELEGRAM_BOT_TOKEN%" ^
  -e OPENCLAUDE_TELEGRAM_HOME_CHAT_ID="%OPENCLAUDE_REPLICA_TELEGRAM_HOME_CHAT_ID%" ^
  -e OPENCLAUDE_TELEGRAM_ALLOWED_CHAT_IDS="%OPENCLAUDE_REPLICA_TELEGRAM_ALLOWED_CHAT_IDS%" ^
  -e OPENCLAUDE_TELEGRAM_ALLOWED_USER_IDS="%OPENCLAUDE_REPLICA_TELEGRAM_ALLOWED_USER_IDS%" ^
  -e OPENCLAUDE_OUROBOROS_ENABLED="%OPENCLAUDE_REPLICA_OUROBOROS_ENABLED%" ^
  -e OPENCLAUDE_CONSCIOUSNESS_ENABLED="%OPENCLAUDE_REPLICA_CONSCIOUSNESS_ENABLED%" ^
  -e OPENCLAUDE_INFINITE_TASKS_ENABLED="%OPENCLAUDE_REPLICA_INFINITE_TASKS_ENABLED%" ^
  -e OPENCLAUDE_OUROBOROS_WAKEUP_MIN_SECONDS="%OPENCLAUDE_REPLICA_OUROBOROS_WAKEUP_MIN_SECONDS%" ^
  -e OPENCLAUDE_OUROBOROS_WAKEUP_MAX_SECONDS="%OPENCLAUDE_REPLICA_OUROBOROS_WAKEUP_MAX_SECONDS%" ^
  -e OPENCLAUDE_OUROBOROS_MAX_ROUNDS="%OPENCLAUDE_REPLICA_OUROBOROS_MAX_ROUNDS%" ^
  -e OPENCLAUDE_OUROBOROS_BUDGET_FRACTION="%OPENCLAUDE_REPLICA_OUROBOROS_BUDGET_FRACTION%" ^
  -e OPENCLAUDE_AGENT_RUNNER_CWD="%OPENCLAUDE_AGENT_RUNNER_CWD%" ^
  -e OPENCLAUDE_AGENT_RUNNER_MAX_TURNS="%OPENCLAUDE_AGENT_RUNNER_MAX_TURNS%" ^
  -e OPENCLAUDE_AGENT_RUNNER_TIMEOUT_MS="%OPENCLAUDE_AGENT_RUNNER_TIMEOUT_MS%" ^
  -e OPENCLAUDE_AGENT_RUNNER_PERMISSION_MODE="%OPENCLAUDE_AGENT_RUNNER_PERMISSION_MODE%" ^
  -e OPENCLAUDE_AGENT_RUNNER_DISALLOWED_TOOLS="%OPENCLAUDE_AGENT_RUNNER_DISALLOWED_TOOLS%" ^
  -e WEB_SEARCH_PROVIDER="%WEB_SEARCH_PROVIDER%" ^
  -e WEB_PROVIDER="%WEB_PROVIDER%" ^
  -e WEB_KEY="%WEB_KEY%" ^
  -e WEB_SEARCH_API="%WEB_SEARCH_API%" ^
  -e WEB_QUERY_PARAM="%WEB_QUERY_PARAM%" ^
  -e WEB_METHOD="%WEB_METHOD%" ^
  -e WEB_PARAMS="%WEB_PARAMS%" ^
  -e WEB_URL_TEMPLATE="%WEB_URL_TEMPLATE%" ^
  -e WEB_BODY_TEMPLATE="%WEB_BODY_TEMPLATE%" ^
  -e WEB_AUTH_HEADER="%WEB_AUTH_HEADER%" ^
  -e WEB_AUTH_SCHEME="%WEB_AUTH_SCHEME%" ^
  -e WEB_HEADERS="%WEB_HEADERS%" ^
  -e WEB_JSON_PATH="%WEB_JSON_PATH%" ^
  -e WEB_CUSTOM_TIMEOUT_SEC="%WEB_CUSTOM_TIMEOUT_SEC%" ^
  -e WEB_CUSTOM_MAX_BODY_KB="%WEB_CUSTOM_MAX_BODY_KB%" ^
  -e WEB_CUSTOM_ALLOW_ARBITRARY_HEADERS="%WEB_CUSTOM_ALLOW_ARBITRARY_HEADERS%" ^
  -e WEB_CUSTOM_ALLOW_HTTP="%WEB_CUSTOM_ALLOW_HTTP%" ^
  -e WEB_CUSTOM_ALLOW_PRIVATE="%WEB_CUSTOM_ALLOW_PRIVATE%" ^
  -e FIRECRAWL_API_KEY="%FIRECRAWL_API_KEY%" ^
  -e TAVILY_API_KEY="%TAVILY_API_KEY%" ^
  -e EXA_API_KEY="%EXA_API_KEY%" ^
  -e YOU_API_KEY="%YOU_API_KEY%" ^
  -e JINA_API_KEY="%JINA_API_KEY%" ^
  -e BING_API_KEY="%BING_API_KEY%" ^
  -e MOJEEK_API_KEY="%MOJEEK_API_KEY%" ^
  -e LINKUP_API_KEY="%LINKUP_API_KEY%" ^
  -e MCPR_HOST="%MCPR_HOST%" ^
  -e MCPR_PORT="%MCPR_PORT%" ^
  -e OPENRAG_URL="%OPENRAG_URL%" ^
  -e OPENRAG_API_KEY="%OPENRAG_API_KEY%" ^
  -e OPENRAG_MCP_TIMEOUT="%OPENRAG_MCP_TIMEOUT%" ^
  -e CAMOFOX_URL="%CAMOFOX_URL%" ^
  -e CAMOFOX_ACCESS_KEY="%CAMOFOX_ACCESS_KEY%" ^
  -e CAMOFOX_API_KEY="%CAMOFOX_API_KEY%" ^
  -e CAMOFOX_MCP_TIMEOUT="%CAMOFOX_MCP_TIMEOUT%" ^
  -e HINDSIGHT_URL="%HINDSIGHT_URL%" ^
  -e HINDSIGHT_API_KEY="%HINDSIGHT_API_KEY%" ^
  -e HINDSIGHT_BANK_ID="%HINDSIGHT_BANK_ID%" ^
  -e HINDSIGHT_MCP_TIMEOUT="%HINDSIGHT_MCP_TIMEOUT%" ^
  -v "%cd%:/workspace" ^
  -v "%NAME%-config:/home/node/.openclaude" ^
  -w /workspace ^
  openclaude-agent:local --agent-gateway-server

echo Replica started: http://127.0.0.1:%PORT%/v1
echo API key: %API_KEY%
echo Container: %NAME%
echo Env file: %ENV_FILE%
echo Telegram enabled: %OPENCLAUDE_REPLICA_TELEGRAM_ENABLED%
