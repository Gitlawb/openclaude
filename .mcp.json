{
  "mcpServers": {
    "mcp-router": {
      "command": "node",
      "args": [
        "scripts/mcp-router-connect.cjs"
      ],
      "env": {
        "MCPR_TOKEN": "${MCPR_TOKEN}"
      }
    },
    "openrag": {
      "command": "node",
      "args": [
        "scripts/release/openrag-mcp-bridge.cjs"
      ],
      "env": {
        "OPENRAG_URL": "http://localhost:3000",
        "OPENRAG_API_KEY": "${OPENRAG_API_KEY}",
        "OPENRAG_MCP_TIMEOUT": "60"
      }
    },
    "camofox": {
      "command": "node",
      "args": [
        "scripts/release/camofox-mcp-bridge.cjs"
      ],
      "env": {
        "CAMOFOX_URL": "http://localhost:9377",
        "CAMOFOX_MCP_USER_ID": "openclaude-agent",
        "CAMOFOX_MCP_SESSION_KEY": "default",
        "CAMOFOX_MCP_TIMEOUT": "60",
        "CAMOFOX_ACCESS_KEY": "${CAMOFOX_ACCESS_KEY}",
        "CAMOFOX_API_KEY": "${CAMOFOX_API_KEY}"
      }
    },
    "hindsight": {
      "command": "node",
      "args": [
        "scripts/release/hindsight-mcp-bridge.cjs"
      ],
      "env": {
        "HINDSIGHT_URL": "http://localhost:8888",
        "HINDSIGHT_BANK_ID": "openclaude-agent",
        "HINDSIGHT_MCP_TIMEOUT": "60",
        "HINDSIGHT_API_KEY": "${HINDSIGHT_API_KEY}"
      }
    }
  }
}
