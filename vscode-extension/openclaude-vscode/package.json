{
  "name": "forge-vscode",
  "displayName": "Atreides Forge",
  "description": "Practical VS Code companion for Atreides Forge with project-aware launch behavior and a real Control Center.",
  "version": "0.1.1",
  "publisher": "devnull-bootloader",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:forge.start",
    "onCommand:forge.startInWorkspaceRoot",
    "onCommand:forge.openDocs",
    "onCommand:forge.openSetupDocs",
    "onCommand:forge.openWorkspaceProfile",
    "onCommand:forge.openControlCenter",
    "onView:forge.controlCenter"
  ],
  "main": "./src/extension.js",
  "files": [
    "README.md",
    "media/**",
    "src/extension.js",
    "src/presentation.js",
    "src/state.js",
    "themes/**"
  ],
  "contributes": {
    "commands": [
      {
        "command": "forge.start",
        "title": "Atreides Forge: Launch in Terminal",
        "category": "Atreides Forge"
      },
      {
        "command": "forge.startInWorkspaceRoot",
        "title": "Atreides Forge: Launch in Workspace Root",
        "category": "Atreides Forge"
      },
      {
        "command": "forge.openDocs",
        "title": "Atreides Forge: Open Repository",
        "category": "Atreides Forge"
      },
      {
        "command": "forge.openSetupDocs",
        "title": "Atreides Forge: Open Setup Guide",
        "category": "Atreides Forge"
      },
      {
        "command": "forge.openWorkspaceProfile",
        "title": "Atreides Forge: Open Workspace Profile",
        "category": "Atreides Forge"
      },
      {
        "command": "forge.openControlCenter",
        "title": "Atreides Forge: Open Control Center",
        "category": "Atreides Forge"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "forge",
          "title": "Atreides Forge",
          "icon": "media/forge.svg"
        }
      ]
    },
    "views": {
      "forge": [
        {
          "id": "forge.controlCenter",
          "name": "Control Center",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Atreides Forge",
      "properties": {
        "forge.launchCommand": {
          "type": "string",
          "default": "forge",
          "description": "Command run in the integrated terminal when launching Atreides Forge."
        },
        "forge.terminalName": {
          "type": "string",
          "default": "Atreides Forge",
          "description": "Integrated terminal tab name for Atreides Forge sessions."
        },
        "forge.useOpenAIShim": {
          "type": "boolean",
          "default": false,
          "description": "Optionally set CLAUDE_CODE_USE_OPENAI=1 in launched Atreides Forge terminals."
        }
      }
    },
    "themes": [
      {
        "label": "Atreides Forge Terminal Black",
        "uiTheme": "vs-dark",
        "path": "./themes/Atreides Forge-Terminal-Black.json"
      }
    ]
  },
  "scripts": {
    "test": "node --test ./src/*.test.js",
    "lint": "node -e \"for (const file of require('node:fs').readdirSync('./src')) { if (file.endsWith('.js')) { require('node:child_process').execFileSync(process.execPath, ['--check', require('node:path').join('src', file)], { stdio: 'inherit' }); } }\"",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "keywords": [
    "forge",
    "terminal",
    "theme",
    "cli",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ambitious-realism/forge"
  },
  "license": "MIT"
}
