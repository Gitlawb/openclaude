# OpenClaude Bot Gateway — Environment Variables
# Copy to .env and fill in your tokens

# ─── Telegram ─────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ─── Discord ──────────────────────────────────────────────
# Get from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# ─── Gateway ──────────────────────────────────────────────
# Health check endpoint port (default: 3000)
HEALTH_PORT=3000

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=info
