{
  "schemaVersion": 1,
  "provider": "bedrock",
  "label": "AWS Bedrock",
  "endpoints": {
    "messages": {
      "path": "/model/{modelId}/invoke-with-response-stream",
      "protocol": "anthropic-messages",
      "streaming": true
    }
  },
  "defaults": {
    "endpoint": "messages",
    "limits": {
      "contextWindow": 128000,
      "maxOutputTokens": {
        "default": 8192,
        "upperLimit": 32768
      }
    },
    "capabilities": {
      "streaming": true,
      "functionCalling": true,
      "jsonMode": true
    },
    "brandId": "claude",
    "vendorId": "anthropic",
    "gatewayId": "bedrock"
  },
  "models": {
    "bedrock-claude-opus": {
      "label": "Claude Opus (Bedrock)",
      "apiName": "us.anthropic.claude-opus-4-6-v1",
      "canonicalModelId": "claude-opus-4-6",
      "brandId": "claude",
      "vendorId": "anthropic",
      "gatewayId": "bedrock",
      "classification": [
        "chat",
        "reasoning",
        "vision",
        "coding"
      ],
      "limits": {
        "contextWindow": 200000,
        "maxOutputTokens": {
          "default": 8192,
          "upperLimit": 8192
        }
      },
      "capabilities": {
        "vision": true,
        "streaming": true,
        "functionCalling": true,
        "jsonMode": true,
        "reasoning": true,
        "preciseTokenCount": false
      }
    }
  }
}
