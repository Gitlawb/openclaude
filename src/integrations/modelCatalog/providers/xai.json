{
  "schemaVersion": 1,
  "provider": "xai",
  "label": "xAI",
  "baseUrl": "https://api.x.ai/v1",
  "endpoints": {
    "chatCompletions": {
      "path": "/chat/completions",
      "protocol": "openai-chat-completions",
      "streaming": true,
      "request": {
        "maxTokensField": "max_tokens"
      }
    },
    "models": {
      "path": "/models",
      "protocol": "models-list"
    }
  },
  "defaults": {
    "endpoint": "chatCompletions",
    "limits": {
      "contextWindow": 128000,
      "maxOutputTokens": {
        "default": 8192,
        "upperLimit": 8192
      }
    },
    "capabilities": {
      "streaming": true,
      "functionCalling": true,
      "jsonMode": true
    },
    "brandId": "xai",
    "vendorId": "xai"
  },
  "models": {
    "grok-4": {
      "label": "Grok 4",
      "classification": [
        "chat",
        "reasoning",
        "vision",
        "coding"
      ],
      "limits": {
        "contextWindow": 2000000,
        "maxOutputTokens": {
          "default": 32768,
          "upperLimit": 32768
        }
      },
      "capabilities": {
        "streaming": true,
        "functionCalling": true,
        "jsonMode": true,
        "vision": true,
        "reasoning": true
      },
      "visibility": {
        "defaultFor": [
          "opus",
          "sonnet",
          "main"
        ]
      }
    },
    "grok-3": {
      "label": "Grok 3",
      "classification": [
        "chat",
        "reasoning",
        "vision",
        "coding"
      ],
      "limits": {
        "contextWindow": 131072,
        "maxOutputTokens": {
          "default": 32768,
          "upperLimit": 32768
        }
      },
      "capabilities": {
        "streaming": true,
        "functionCalling": true,
        "jsonMode": true,
        "vision": true,
        "reasoning": true
      },
      "visibility": {
        "defaultFor": [
          "haiku",
          "smallFast"
        ]
      }
    }
  },
  "discovery": {
    "endpoint": "models",
    "parser": "openai-models-list",
    "cacheTtl": "1d",
    "refreshMode": "background-if-stale"
  }
}
