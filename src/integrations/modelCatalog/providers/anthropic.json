    },
    "haiku45Pricing": {
      "pricing": {
        "input": 1,
        "output": 5,
        "cacheWrite": 1.25,
        "cacheRead": 0.1,
        "webSearch": 0.01
      }
    },
    "claude4": {
      "classification": [
        "chat",
        "reasoning",
        "vision",
        "coding"
      ],
      "capabilities": {
        "streaming": true,
        "functionCalling": true,
        "jsonMode": true,
        "vision": true,
        "reasoning": true,
        "thinking": true,
        "interleavedThinking": true,
