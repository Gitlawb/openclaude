{
  "schemaVersion": 1,
  "provider": "anthropic",
  "label": "Anthropic",
  "baseUrl": "https://api.anthropic.com",
  "endpoints": {
    "messages": {
      "path": "/v1/messages",
      "protocol": "anthropic-messages",
      "streaming": true
    },
    "models": {
      "path": "/v1/models",
      "protocol": "models-list"
    }
  },
  "defaults": {
    "endpoint": "messages",
    "limits": {
      "contextWindow": 200000,
      "maxOutputTokens": {
        "default": 32000,
        "upperLimit": 64000
      },
      "compactMaxOutputTokens": 20000
    },
    "capabilities": {
      "streaming": true,
      "functionCalling": true,
      "jsonMode": true,
      "vision": true,
      "reasoning": true,
      "thinking": true,
      "interleavedThinking": true,
      "contextManagement": true,
      "promptCaching": true,
      "webSearch": true
    },
    "brandId": "claude",
    "vendorId": "anthropic"
  },
  "templates": {
    "sonnetPricing": {
      "family": "sonnet",
      "pricing": {
        "input": 3,
        "output": 15,
        "cacheWrite": 3.75,
        "cacheRead": 0.3,
        "webSearch": 0.01
      },
      "ui": {
        "upgradeHintFamily": "Sonnet"
      }
    },
    "opusLegacyPricing": {
      "family": "opus",
      "pricing": {
        "input": 15,
        "output": 75,
        "cacheWrite": 18.75,
        "cacheRead": 1.5,
        "webSearch": 0.01
      },
      "ui": {
        "upgradeHintFamily": "Opus"
      }
    },
    "opusModernPricing": {
      "family": "opus",
      "pricing": {
        "input": 5,
        "output": 25,
        "cacheWrite": 6.25,
        "cacheRead": 0.5,
        "webSearch": 0.01
      },
      "ui": {
        "upgradeHintFamily": "Opus"
      }
    },
    "haiku35Pricing": {
      "family": "haiku",
      "pricing": {
        "input": 0.8,
        "output": 4,
        "cacheWrite": 1,
        "cacheRead": 0.08,
        "webSearch": 0.01
      },
      "ui": {
        "upgradeHintFamily": "Haiku"
      }
    },
    "haiku45Pricing": {
      "family": "haiku",
      "pricing": {
        "input": 1,
        "output": 5,
        "cacheWrite": 1.25,
        "cacheRead": 0.1,
        "webSearch": 0.01
      },
      "ui": {
        "upgradeHintFamily": "Haiku"
      }
    },
    "claude4": {
      "classification": [
        "chat",
        "reasoning",
        "vision",
        "coding"
      ],
      "capabilities": {
        "streaming": true,
        "functionCalling": true,
        "jsonMode": true,
        "vision": true,
        "reasoning": true,
        "thinking": true,
        "interleavedThinking": true,
        "contextManagement": true,
        "promptCaching": true,
        "webSearch": true
      },
      "ui": {
        "knowledgeCutoff": "January 2025"
      }
    },
    "claude3": {
      "classification": [
        "chat",
        "vision"
      ],
      "limits": {
        "contextWindow": 200000,
        "compactMaxOutputTokens": 20000
      },
      "capabilities": {
        "streaming": true,
        "functionCalling": true,
        "jsonMode": true,
        "vision": true,
        "reasoning": false,
