{
  "schemaVersion": 1,
  "provider": "atomic-chat",
  "label": "Atomic Chat",
  "baseUrl": "http://127.0.0.1:1337/v1",
  "endpoints": {
    "chatCompletions": {
      "path": "/chat/completions",
      "protocol": "openai-chat-completions",
      "streaming": true,
      "request": {
        "maxTokensField": "max_tokens"
      }
    },
    "models": {
      "path": "/models",
      "protocol": "models-list"
    }
  },
  "defaults": {
    "endpoint": "chatCompletions",
    "limits": {
      "contextWindow": 128000,
      "maxOutputTokens": {
        "default": 8192,
        "upperLimit": 32768
      }
    },
    "capabilities": {
      "streaming": true,
      "functionCalling": true,
      "jsonMode": true
    }
  },
  "models": {
    "local-model": {
      "label": "Local model",
      "apiName": "local-model",
      "classification": [
        "chat"
      ],
      "visibility": {
        "hidden": true
      }
    }
  },
  "discovery": {
    "endpoint": "models",
    "parser": "openai-models-list",
    "requiresAuth": false,
    "cacheTtl": "1d",
    "refreshMode": "background-if-stale"
  }
}
