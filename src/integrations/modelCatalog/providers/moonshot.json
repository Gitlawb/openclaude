{
  "schemaVersion": 1,
  "provider": "moonshot",
  "label": "Moonshot AI",
  "baseUrl": "https://api.moonshot.ai/v1",
  "endpoints": {
    "chatCompletions": {
      "path": "/chat/completions",
      "protocol": "openai-chat-completions",
      "streaming": true,
      "request": {
        "preserveReasoningContent": true,
        "requireReasoningContentOnAssistantMessages": true,
        "reasoningContentFallback": "",
        "maxTokensField": "max_tokens",
        "removeBodyFields": [
          "store"
        ]
      }
    },
    "models": {
      "path": "/models",
      "protocol": "models-list"
    }
  },
  "defaults": {
    "endpoint": "chatCompletions",
    "limits": {
      "contextWindow": 128000,
      "maxOutputTokens": {
        "default": 8192,
        "upperLimit": 8192
      }
    },
    "capabilities": {
      "streaming": true,
      "functionCalling": true,
      "jsonMode": true
    },
    "brandId": "kimi",
    "vendorId": "moonshot"
  },
  "models": {
    "kimi-for-coding": {
      "label": "Kimi for Coding",
      "classification": [
        "chat",
        "reasoning",
        "vision",
        "coding"
      ],
      "limits": {
        "contextWindow": 262144,
        "maxOutputTokens": {
          "default": 32768,
          "upperLimit": 32768
        }
      },
      "capabilities": {
        "streaming": true,
        "functionCalling": true,
        "jsonMode": true,
        "vision": true,
        "reasoning": true
      },
      "visibility": {
        "defaultFor": [
          "haiku",
          "smallFast"
        ]
      }
    },
