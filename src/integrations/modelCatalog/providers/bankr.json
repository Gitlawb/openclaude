{
  "schemaVersion": 1,
  "provider": "bankr",
  "label": "Bankr",
  "baseUrl": "https://llm.bankr.bot/v1",
  "endpoints": {
    "chatCompletions": {
      "path": "/chat/completions",
      "protocol": "openai-chat-completions",
      "streaming": true,
      "request": {
        "maxTokensField": "max_tokens"
      }
    },
    "models": {
      "path": "/models",
      "protocol": "models-list"
    }
  },
  "defaults": {
    "endpoint": "chatCompletions",
    "limits": {
      "contextWindow": 128000,
      "maxOutputTokens": {
        "default": 8192,
        "upperLimit": 32768
      }
    },
    "capabilities": {
      "streaming": true,
      "functionCalling": true,
      "jsonMode": true
    }
  },
  "models": {
    "claude-opus-4.6": {
      "label": "Claude Opus 4.6",
      "apiName": "claude-opus-4.6",
      "canonicalModelId": "claude-opus-4-6",
      "brandId": "claude",
      "vendorId": "anthropic",
      "classification": [
        "chat",
        "reasoning",
        "vision",
        "coding"
      ],
      "limits": {
        "contextWindow": 200000,
        "maxOutputTokens": {
          "default": 8192,
          "upperLimit": 8192
        }
      },
      "capabilities": {
        "vision": true,
        "streaming": true,
        "functionCalling": true,
        "jsonMode": true,
        "reasoning": true,
        "preciseTokenCount": false
      },
      "visibility": {
        "defaultFor": [
          "main"
        ]
      }
    }
  }
}
