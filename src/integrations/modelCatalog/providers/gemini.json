{
  "schemaVersion": 1,
  "provider": "gemini",
  "label": "Google Gemini",
  "baseUrl": "https://generativelanguage.googleapis.com/v1beta/openai",
  "endpoints": {
    "chatCompletions": {
      "path": "/chat/completions",
      "protocol": "gemini-native",
      "streaming": true,
      "request": {
        "maxTokensField": "max_tokens",
        "removeBodyFields": [
          "store"
        ]
      }
    },
    "models": {
      "path": "/models",
      "protocol": "models-list"
    }
  },
  "defaults": {
    "endpoint": "chatCompletions",
    "limits": {
      "contextWindow": 128000,
      "maxOutputTokens": {
        "default": 8192,
        "upperLimit": 8192
      }
    },
    "capabilities": {
      "streaming": true,
      "functionCalling": true,
      "jsonMode": true
    },
    "brandId": "gemini",
    "vendorId": "gemini"
  },
  "models": {
